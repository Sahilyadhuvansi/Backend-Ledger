# Backend Ledger AI - Environment Configuration
NODE_ENV=development
PORT=3000

# Database
MONGO_URI=mongodb://localhost:27017/backend-ledger-ai

# Authentication
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRES_IN=7d

# CORS & Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Email
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# AI Services
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_CLOUD_KEY_FILE=./config/google-cloud-key.json
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=backend-ledger-ai

# AI Feature Toggles
AI_CHATBOT_ENABLED=true
AI_FRAUD_DETECTION_ENABLED=true
AI_CATEGORIZATION_ENABLED=true

# AI Cost Controls
AI_DAILY_BUDGET=10.00
ALERT_EMAIL=admin@example.com
