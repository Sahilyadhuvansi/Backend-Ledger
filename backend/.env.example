PORT=3000
MONGO_URI=mongodb://localhost:27017/ledgerpro
JWT_SECRET=your_super_secret_key_here_minimum_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Email — use EMAIL_PASS for simple app password auth (recommended for dev)
# Leave EMAIL_PASS empty to use OAuth2 (recommended for production)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# OAuth2 credentials (only needed if EMAIL_PASS is not set)
CLIENT_ID=your_oauth2_client_id
CLIENT_SECRET=your_oauth2_client_secret
REFRESH_TOKEN=your_oauth2_refresh_token
